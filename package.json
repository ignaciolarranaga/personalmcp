{
  "name": "aiprofile",
  "version": "0.1.0",
  "description": "A local-first MCP server for structured, agent-readable identity and context profiles",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ignaciolarranaga/aiprofile.git"
  },
  "homepage": "https://github.com/ignaciolarranaga/aiprofile#readme",
  "bugs": {
    "url": "https://github.com/ignaciolarranaga/aiprofile/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aiprofile": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "config.yaml"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "node dist/index.js serve",
    "start": "node dist/index.js serve",
    "auth": "node dist/index.js auth",
    "setup-model": "node dist/index.js setup-model",
    "memory": "node dist/index.js memory"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "node-llama-cpp": "^3.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
