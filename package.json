{
  "name": "personalmcp",
  "version": "0.1.0",
  "description": "A local-first MCP server that acts as a personal digital twin",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.scripts.json",
    "lint": "eslint src scripts tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "node dist/index.js",
    "start": "node dist/index.js",
    "setup:model": "node dist/scripts/setup-model.js",
    "memory": "node dist/memory-cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.9.0",
    "js-yaml": "^4.1.0",
    "node-llama-cpp": "^3.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
